# NGC CLI API Key for pulling NVIDIA container images
NGC_CLI_API_KEY=

# Host IP address - must be set to your machine's IP for external connectivity
# Determine with: ip route get 1.1.1.1 | awk '{print $7; exit}'
HOST_IP=

# Path to data directory containing videos and models
DATA_DIR=./data

# Number of sensors/streams to process
NUM_SENSORS=1

# NVIDIA VSS component image tags
PERCEPTION_TAG=3.1.0
NVSTREAMER_TAG=3.1.0
SDR_TAG=3.1.0

# Postgres credentials (used by both the postgres and backend services)
POSTGRES_PASSWORD=aims
DATABASE_URL=postgresql://aims:aims@postgres:5432/aims

# Support/dev logging. Use LOG_FORMAT=json for portable stdout JSON Lines
# suitable for Loki/Grafana parsing; keep IDs as JSON fields, not labels.
ENV=dev
LOG_LEVEL=INFO
LOG_FORMAT=text
SERVICE_NAME=aims-backend
NEXT_PUBLIC_LOG_LEVEL=INFO
NEXT_PUBLIC_LOG_FORMAT=text
NEXT_PUBLIC_SERVICE_NAME=aims-frontend

# Optional Loki/Grafana support-dev log UI
LOKI_TAG=2.9.8
PROMTAIL_TAG=3.4.1
GRAFANA_TAG=10.4.3
LOKI_PORT=3100
GRAFANA_PORT=3002
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
DOCKER_API_VERSION=1.44

# === VLM provider selection ===
# Choose ONE of:
#   cosmos  → local NIM container (GPU required, no per-call cost)
#   openai  → OpenAI API or any OAI-compatible endpoint via OPENAI_BASE_URL
VLM_PROVIDER=cosmos

# Cosmos (self-hosted) — used only when VLM_PROVIDER=cosmos
COSMOS_URL=http://cosmos:8000
COSMOS_MODEL=nvidia/cosmos-reason2-2b

# OpenAI (proprietary) — used only when VLM_PROVIDER=openai
# Get a key from https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
# Optional — point at any OAI-compatible endpoint (vLLM, Ollama, etc.)
OPENAI_BASE_URL=

# Shared
VLM_ENABLED=false
VLM_TIMEOUT_S=120
VLM_FRAME_FPS=1
