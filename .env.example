# NGC CLI API Key for pulling NVIDIA container images
NGC_CLI_API_KEY=

# Host IP address - must be set to your machine's IP for external connectivity
# Determine with: ip route get 1.1.1.1 | awk '{print $7; exit}'
HOST_IP=

# Path to data directory containing videos and models
DATA_DIR=./data

# Number of sensors/streams to process
NUM_SENSORS=1

# NVIDIA VSS component image tags
PERCEPTION_TAG=3.1.0
NVSTREAMER_TAG=3.1.0
SDR_TAG=3.1.0

# Backend reads DATABASE_URL — points at the supabase db service.
DATABASE_URL=postgresql://postgres:postgres@db:5432/postgres

# Support/dev logging. Use LOG_FORMAT=json for portable stdout JSON Lines
# suitable for Loki/Grafana parsing; keep IDs as JSON fields, not labels.
ENV=dev
LOG_LEVEL=INFO
LOG_FORMAT=text
SERVICE_NAME=aims-backend
NEXT_PUBLIC_LOG_LEVEL=INFO
NEXT_PUBLIC_LOG_FORMAT=text
NEXT_PUBLIC_SERVICE_NAME=aims-frontend

# Optional Loki/Grafana support-dev log UI
LOKI_TAG=2.9.8
PROMTAIL_TAG=3.4.1
GRAFANA_TAG=10.4.3
LOKI_PORT=3100
GRAFANA_PORT=3002
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
DOCKER_API_VERSION=1.44

# === VLM provider selection ===
# Choose ONE of:
#   cosmos  → local NIM container (GPU required, no per-call cost)
#   openai  → OpenAI API or any OAI-compatible endpoint via OPENAI_BASE_URL
VLM_PROVIDER=cosmos

# Cosmos (self-hosted) — used only when VLM_PROVIDER=cosmos
COSMOS_URL=http://cosmos:8000
COSMOS_MODEL=nvidia/cosmos-reason2-2b

# OpenAI (proprietary) — used only when VLM_PROVIDER=openai
# Get a key from https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
# Optional — point at any OAI-compatible endpoint (vLLM, Ollama, etc.)
OPENAI_BASE_URL=https://ai-gateway.vercel.sh/v1

# Shared
VLM_ENABLED=false
VLM_TIMEOUT_S=120
VLM_FRAME_FPS=1

# === Supabase (self-hosted) ===
# Generate fresh values for every environment. Helper:
#   sh ./utils/generate-keys.sh   (from supabase/docker)
# or follow https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys

# 32+ byte HS256 secret. Signs every Supabase-issued JWT.
JWT_SECRET=your-jwt-secret-32-chars-minimum

# Pre-signed JWTs derived from JWT_SECRET (anon + service_role).
ANON_KEY=
SERVICE_ROLE_KEY=

# Internal Supabase service secrets (not consumed by the trimmed stack
# but kept here so a fuller stack can be enabled without re-templating).
SECRET_KEY_BASE=your-secret-key-base-64-chars
VAULT_ENC_KEY=your-32-character-encryption-key
PG_META_CRYPTO_KEY=your-encryption-key-32-chars-min
LOGFLARE_PUBLIC_ACCESS_TOKEN=your-logflare-public-token
LOGFLARE_PRIVATE_ACCESS_TOKEN=your-logflare-private-token

# Storage backend (MinIO acting as S3-compatible store)
S3_PROTOCOL_ACCESS_KEY_ID=
S3_PROTOCOL_ACCESS_KEY_SECRET=
MINIO_ROOT_USER=supa-storage
MINIO_ROOT_PASSWORD=
GLOBAL_S3_BUCKET=stub
REGION=stub
STORAGE_TENANT_ID=stub
STORAGE_S3_ENDPOINT=http://minio:9000

# Postgres + Studio dashboard
POSTGRES_PASSWORD=
DASHBOARD_PASSWORD=

# Single-tenant: signups disabled, operator provisioned out-of-band.
GOTRUE_DISABLE_SIGNUP=true
SITE_URL=http://localhost:3000
API_EXTERNAL_URL=http://localhost:8000
KONG_HTTP_PORT=8000

# Frontend reads these at build time — kong gateway is the public face.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ----- Payload CMS -----
# Postgres connection for Payload (uses payload schema in the same Supabase Postgres)
DATABASE_URI=postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/postgres?search_path=payload
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=
# MinIO bucket for Payload media uploads
PAYLOAD_S3_BUCKET=payload-media
# Note: Payload reuses S3_PROTOCOL_ACCESS_KEY_ID, S3_PROTOCOL_ACCESS_KEY_SECRET,
# STORAGE_S3_ENDPOINT, REGION (defined above) for media upload auth.
