# Copy to .env.local for local `npm run dev` against docker-compose.dev.yml.
# (Inside the full docker stack this is unnecessary — compose service DNS
#  resolves "backend" automatically.)
BACKEND_URL=http://localhost:8080

# Supabase — Kong gateway URL (matches KONG_HTTP_PORT in the repo-root .env;
# default 8000). The anon key is the public JWT signed with JWT_SECRET.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Payload CMS — only needed when running `npm run dev` / `npm run seed` from the host.
# Inside the docker stack Payload reads the repo-root .env where host=db works.
# On the host: use localhost (the supabase-db port is published) and paste the
# literal POSTGRES_PASSWORD value from repo-root .env — Next's dotenv does not
# expand vars across files.
DATABASE_URI=postgresql://postgres:<paste-POSTGRES_PASSWORD>@localhost:5432/postgres?search_path=payload
PAYLOAD_SECRET=<openssl rand -hex 32>
PAYLOAD_S3_BUCKET=payload-media
