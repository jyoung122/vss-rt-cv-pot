# Copy to .env.local for local `npm run dev` against docker-compose.dev.yml.
# (Inside the full docker stack this is unnecessary — compose service DNS
#  resolves "backend" automatically.)
BACKEND_URL=http://localhost:8080

# Supabase — Kong gateway URL (matches KONG_HTTP_PORT in the repo-root .env;
# default 8000). The anon key is the public JWT signed with JWT_SECRET.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=
